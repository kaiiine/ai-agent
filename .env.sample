# ──────────────────────────────────────────────────────────────
#  Axon — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs nécessaires
#  selon les fonctionnalités que tu veux utiliser.
# ──────────────────────────────────────────────────────────────

# ── IDENTITÉ ──────────────────────────────────────────────────
USER_NAME=Ton Prénom Nom

# ── REQUIS ────────────────────────────────────────────────────

# Recherche web (https://app.tavily.com)
TAVILY_API_KEY=tvly-...

# ── BACKENDS LLM ──────────────────────────────────────────────

# Groq API (https://console.groq.com) — backend "groq"
GROQ_API_KEY=gsk_...

# Ollama Cloud (https://ollama.com/settings/api-keys) — backend "ollama_cloud" avec compte
# Laisser vide pour utiliser ollama_cloud sans clé (modèles locaux signés via `ollama signin`)
OLLAMA_API_KEY=

# Adresse de l'instance Ollama locale
OLLAMA_HOST=http://127.0.0.1:11434

# ── GOOGLE SERVICES ───────────────────────────────────────────
# Gmail · Calendar · Drive · Docs · Slides
#
# Prérequis : fichier gcp-oauth.keys.json à la racine du projet
# (OAuth2 — téléchargeable depuis Google Cloud Console)
# Le token est sauvegardé automatiquement dans ~/.ai-agent/google_token.pickle
# lors du premier lancement.
#
# Scopes requis : gmail, calendar, drive, docs, slides, sheets
# Pas de variable d'environnement nécessaire ici — tout passe par gcp-oauth.keys.json

# ── SLACK ─────────────────────────────────────────────────────
# User Token Slack (https://api.slack.com/apps → OAuth & Permissions → User Token Scopes)
# Scopes requis : channels:read, channels:history,
#                 groups:read, groups:history,
#                 im:read, im:history, im:write,
#                 mpim:read, mpim:history, mpim:write,
#                 users:read, search:read, chat:write
SLACK_USER_TOKEN=xoxp-...

# ── JIRA ──────────────────────────────────────────────────────
# URL de ton instance Jira (https://ton-domaine.atlassian.net)
# API token → https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://ton-domaine.atlassian.net
JIRA_EMAIL=ton@email.com
JIRA_API_KEY=ATATT3x...


# ── PROJETS ───────────────────────────────────────────────────
# Dossier racine contenant tes projets locaux (git repos, code...)
# Laisser vide → l'IA cherchera depuis $HOME (plus lent)
PROJECTS_DIR=

# ── DIVERS ────────────────────────────────────────────────────
APP_ENV=dev
